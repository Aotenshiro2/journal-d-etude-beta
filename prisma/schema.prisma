generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Note {
  id          String    @id @default(uuid())
  title       String    @default("Nouvelle note")
  content     String    @default("")
  contentHash String?
  userId      String
  source      String?
  sourceUrl   String?
  favicon     String?
  lastSyncAt       DateTime?  // dernier push depuis l'extension
  deletedAt        DateTime?
  createdAt        DateTime?  // date originale de capture dans l'extension (ancien capturedAt)
  extensionVersion String?    // version de l'extension au moment de la capture
  extensionNoteId  String?    // ID de la note dans l'extension (clé d'upsert prioritaire)
  firstSyncAt      DateTime   @default(now())  // première entrée en DB
  lastModifiedAt   DateTime   @updatedAt       // dernière modification dans le journal
  concepts    String[]  @default([])  // concepts extraits par la smart capture (pas la taxonomie user)
  trades      Json?     // segments de trade [{id, startedAt, closedAt?, outcome?}] — source de vérité extension
  folderId    String?   // dossier extension (couplage lâche, cf. model Folder)
  messages    Message[]
  canvas      Canvas?
  tags        NoteTag[]
  annotations Annotation[]

  // Note: @@unique([userId, sourceUrl]) replaced by a partial DB index (see SQL migration):
  // CREATE UNIQUE INDEX "Note_userId_sourceUrl_legacy_idx" ON "Note" ("userId","sourceUrl") WHERE "extensionNoteId" IS NULL
  // → legacy notes (no extensionNoteId): 1 per URL max; extension notes: N per URL allowed
  @@index([userId])
  @@index([userId, extensionNoteId])
}

model Message {
  id      String       @id @default(uuid())
  noteId  String
  content String
  order   Int
  type    String       @default("text")
  extensionMessageId String? // ID stable du message côté extension (survit au replace-all de la sync)
  tradeRef String?            // segment de trade auquel le bloc appartient (réassignable)
  note    Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tags    MessageTag[]

  @@index([noteId])
}

model Canvas {
  id              String       @id @default(uuid())
  type            String
  userId          String
  noteId          String?      @unique
  noteContentHash String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  note            Note?        @relation(fields: [noteId], references: [id], onDelete: Cascade)
  nodes           CanvasNode[]
  edges           CanvasEdge[]

  @@index([userId])
}

model CanvasNode {
  id        String       @id @default(uuid())
  canvasId  String
  messageId String?
  noteId    String?
  kind      String       @default("message") // 'message' | 'group' | 'text' (bloc libre)
  content   String?      // surcharge locale (copie de travail) ou contenu du bloc libre — l'original reste intact
  label     String?      // nom du groupe (proto-concept)
  color     String?      // clé de palette du groupe
  parentId  String?      // groupe parent — x/y alors RELATIFS au parent (convention React Flow)
  orderInParent Int?     // ordre manuel dans le groupe (projection document, lot 3.5)
  x         Float
  y         Float
  width     Float        @default(280)
  height    Float        @default(120)
  canvas    Canvas       @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  fromEdges CanvasEdge[] @relation("EdgeFrom")
  toEdges   CanvasEdge[] @relation("EdgeTo")

  @@index([canvasId])
  @@index([parentId])
}

model CanvasEdge {
  id       String     @id @default(uuid())
  canvasId String
  fromId   String
  toId     String
  label    String?
  style    String     @default("curved")
  canvas   Canvas     @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  from     CanvasNode @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to       CanvasNode @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

model Tag {
  id        String       @id @default(uuid())
  name      String
  category  String?
  color     String       @default("#3b82f6")
  userId    String
  createdAt DateTime     @default(now())
  messages  MessageTag[]
  notes     NoteTag[]

  @@unique([name, userId])
  @@index([userId])
}

model MessageTag {
  messageId String
  tagId     String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([messageId, tagId])
}

// Dossiers de l'extension (id = uuid extension) — la sync les upserte, le pull les restaure
model Folder {
  id        String   @id
  userId    String
  name      String
  createdAt DateTime @default(now())

  @@index([userId])
}

// Tag au niveau note (grouper les cours par thème) — même taxonomie Tag que les messages
model NoteTag {
  noteId String
  tagId  String
  note   Note @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([noteId, tagId])
}

// La « notation » (masterclass edge) : un jugement posé en 2e temps, découplé du résultat.
// grade A/B/C + une phrase de justification + catégorie de cause, puis cycle de relecture.
// Ciblage message : via extensionMessageId (String libre, PAS de FK) — les messages sont
// détruits/recréés à chaque sync extension, une FK serait cascadée à tort.
model Annotation {
  id            String    @id @default(uuid())
  userId        String
  noteId        String?
  messageRef    String?   // extensionMessageId (note extension) ou Message.id (note journal)
  tradeRef      String?   // TradeSegment.id — jugement d'un trade (vision + cause du SL)
  grade         String    // 'A' | 'B' | 'C'
  phrase        String    // « pourquoi ce trade/cette note mérite cette note »
  causeCategory String?   // 'technique' | 'connaissance' | 'emotionnel'
  createdAt     DateTime  @default(now())
  reviewDueAt   DateTime? // échéance de relecture (~2 semaines)
  reviewedAt    DateTime? // relue le (null = pas encore relue)
  note          Note?     @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([userId, reviewDueAt])
  @@index([noteId])
}
