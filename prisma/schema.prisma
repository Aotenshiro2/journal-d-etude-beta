generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Note {
  id          String    @id @default(uuid())
  title       String    @default("Nouvelle note")
  content     String    @default("")
  contentHash String?
  userId      String
  source      String?
  sourceUrl   String?
  favicon     String?
  syncedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
  canvas      Canvas?

  @@index([userId])
  @@index([sourceUrl])
}

model Message {
  id      String       @id @default(uuid())
  noteId  String
  content String
  order   Int
  type    String       @default("text")
  note    Note         @relation(fields: [noteId], references: [id], onDelete: Cascade)
  tags    MessageTag[]

  @@index([noteId])
}

model Canvas {
  id              String       @id @default(uuid())
  type            String
  userId          String
  noteId          String?      @unique
  noteContentHash String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  note            Note?        @relation(fields: [noteId], references: [id], onDelete: Cascade)
  nodes           CanvasNode[]
  edges           CanvasEdge[]

  @@index([userId])
}

model CanvasNode {
  id        String       @id @default(uuid())
  canvasId  String
  messageId String?
  noteId    String?
  x         Float
  y         Float
  width     Float        @default(280)
  height    Float        @default(120)
  canvas    Canvas       @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  fromEdges CanvasEdge[] @relation("EdgeFrom")
  toEdges   CanvasEdge[] @relation("EdgeTo")

  @@index([canvasId])
}

model CanvasEdge {
  id       String     @id @default(uuid())
  canvasId String
  fromId   String
  toId     String
  label    String?
  style    String     @default("curved")
  canvas   Canvas     @relation(fields: [canvasId], references: [id], onDelete: Cascade)
  from     CanvasNode @relation("EdgeFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to       CanvasNode @relation("EdgeTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

model Tag {
  id        String       @id @default(uuid())
  name      String
  category  String?
  color     String       @default("#3b82f6")
  userId    String
  createdAt DateTime     @default(now())
  messages  MessageTag[]

  @@unique([name, userId])
  @@index([userId])
}

model MessageTag {
  messageId String
  tagId     String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([messageId, tagId])
}
